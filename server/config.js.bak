import path from 'path';
import { fileURLToPath } from 'url';
import { createRequire } from 'module';
import fs from 'fs';
import { resolveScriptsConfig } from './utils/pathResolver.js';
import { ethers } from 'ethers';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// 创建 require 函数用于导入 CommonJS 模块
const require = createRequire(import.meta.url);

// 使用路径工具获取脚本配置路径
const scriptConfigPath = resolveScriptsConfig(import.meta.url);
const scriptsConfig = require(scriptConfigPath);

// 路径验证
console.log('='.repeat(60));
console.log('🔧 配置文件路径验证');
console.log(`- 当前文件: ${__filename}`);
console.log(`- 脚本配置路径: ${scriptConfigPath}`);
console.log(`- 脚本配置存在: ${fs.existsSync(scriptConfigPath) ? '是' : '否'}`);
console.log('='.repeat(60));

// 确保正确导出区块链配置（从主配置导入）
export const BLOCKCHAIN_CONFIG = {
  CONTRACT_ADDRESS: scriptsConfig.contractAddress,
  RPC_URL: scriptsConfig.rpcUrl,
  CHAIN_ID: scriptsConfig.chainId
};

// 定义统一的图片存储路径
export const IMAGE_STORAGE_PATH = path.join(__dirname, '../server/image_storage');

// 定义图片访问的URL基础路径
export const IMAGE_BASE_URL = '/api/images';

export const JWT_SECRET = process.env.JWT_SECRET || 'your-secret-key';
export const PORT = process.env.PORT || 3002;
export const ALLOWED_ORIGINS = ['http://localhost:3000', 'http://localhost:3002'];

// 验证配置是否有效
console.log('🔧 加载服务器配置:');
console.log(`- 合约地址: ${BLOCKCHAIN_CONFIG.CONTRACT_ADDRESS}`);
console.log(`- RPC URL: ${BLOCKCHAIN_CONFIG.RPC_URL}`);
console.log(`- 链ID: ${BLOCKCHAIN_CONFIG.CHAIN_ID}`);
console.log(`- 图片存储路径: ${IMAGE_STORAGE_PATH}`);
console.log(`- 图片基础URL: ${IMAGE_BASE_URL}`);

// 检查图片存储目录
if (!fs.existsSync(IMAGE_STORAGE_PATH)) {
  console.warn('⚠️ 图片存储目录不存在，正在创建...');
  fs.mkdirSync(IMAGE_STORAGE_PATH, { recursive: true });
}

export async function loadConfig() {
  console.log('🔄 重新加载配置...');
  
  // 删除缓存
  delete require.cache[require.resolve(scriptConfigPath)];
  
  // 重新加载配置
  const newConfig = require(scriptConfigPath);
  
  // 更新导出值
  BLOCKCHAIN_CONFIG.CONTRACT_ADDRESS = newConfig.contractAddress;
  BLOCKCHAIN_CONFIG.RPC_URL = newConfig.rpcUrl;
  BLOCKCHAIN_CONFIG.CHAIN_ID = newConfig.chainId;
  
  console.log('✅ 配置已更新');
  console.log(`- 新合约地址: ${BLOCKCHAIN_CONFIG.CONTRACT_ADDRESS}`);
}

// 合约地址验证函数
export async function validateContractAddress() {
  try {
    const provider = new ethers.JsonRpcProvider(BLOCKCHAIN_CONFIG.RPC_URL);
    const code = await provider.getCode(BLOCKCHAIN_CONFIG.CONTRACT_ADDRESS);
    
    if (code === '0x') {
      console.error('❌ 合约地址没有代码 - 合约未部署');
      return false;
    }
    
    console.log('✅ 合约验证成功');
    return true;
  } catch (error) {
    console.error('❌ 合约验证失败:', error.message);
    return false;
  }
}

// 在配置加载后自动验证
setTimeout(async () => {
  await validateContractAddress();
}, 1000);