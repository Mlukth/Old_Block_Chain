import express from 'express';
const router = express.Router();
import jwt from 'jsonwebtoken';
import bcrypt from 'bcrypt';
import db from '../db/index.js';
// 修复: 删除无效声明 (2025-07-19T09:48:36.795Z)
import {  validateLogin  } from '../middleware/validation.js';
import {  authenticateToken  } from '../middleware/auth.js';

// 测试路由 - 用于检查路由是否正常工作
router.get('/test', (req, res) => {
  res.json({ message: '认证路由测试正常', timestamp: new Date().toISOString() });
});

// 测试登录路由 - 仅验证用户是否存在，不验证密码
// 注意：此路由仅用于开发和测试环境，生产环境应禁用
router.post(
  '/test-login', 
  validateLogin,
  async (req, res) => {
    try {
      const { username } = req.body;
      console.log('🔐 收到测试登录请求:', { 
        username, 
        timestamp: new Date().toISOString() 
      });
      
      // 从数据库查询用户
      const user = db.getUserByUsername(username);
      
      if (!user) {
        console.log('🚫 测试登录失败：用户不存在', { username });
        return res.status(401).json({ 
          success: false, 
          error: '用户不存在',
          code: 'USER_NOT_FOUND'
        });
      }
      
      // 生成令牌（跳过密码验证）
      const token = jwt.sign(
        { 
          userId: user.id, 
          username: user.username, 
          role: user.role,
          iat: Math.floor(Date.now() / 1000),
          exp: Math.floor(Date.now() / 1000) + (60 * 60) // 1小时过期
        },
        process.env.JWT_SECRET || 'your-secret-key',
        { algorithm: 'HS256' }
      );
      
      console.log('✅ 测试登录成功:', { username, userId: user.id });
      
      res.json({ 
        success: true, 
        token,
        user: {
          id: user.id,
          username: user.username,
          role: user.role
        }
      });
    } catch (error) {
      console.error('💥 测试登录异常:', {
        errorMessage: error.message,
        errorStack: error.stack,
        timestamp: new Date().toISOString()
      });
      
      res.status(500).json({ 
        success: false, 
        error: '测试登录过程中发生错误',
        code: 'INTERNAL_SERVER_ERROR'
      });
    }
  }
);

// 真实登录路由 - 严格按照条件修改
router.post(
  '/login', 
  validateLogin, // 只保留验证中间件
  async (req, res) => {
    try {
      const { username, password } = req.body;
      console.log('🔐 收到真实登录请求:', { username }); // 移除时间戳
      
      // 从数据库查询用户
      const user = db.getUserByUsername(username);
      
      if (!user) {
        console.log('🚫 登录失败：用户不存在', { username });
        return res.status(401).json({ error: '用户名或密码错误' }); // 移除success和code
      }
      
      // 验证密码
      const isPasswordValid = await bcrypt.compare(password, user.passwordHash);
      
      if (!isPasswordValid) {
        console.log('🚫 登录失败：密码错误', { username });
        return res.status(401).json({ error: '用户名或密码错误' }); // 移除success和code
      }
      
      // 生成令牌（简化配置）
      const token = jwt.sign(
        { userId: user.id, username: user.username, role: user.role },
        process.env.JWT_SECRET || 'your-secret-key',
        { expiresIn: '1h' }
      );
      
      console.log('✅ 真实登录成功:', { username, userId: user.id });
      
      // 调整响应格式（移除user.id）
      res.json({ 
        success: true, 
        token, 
        user: { username: user.username, role: user.role } 
      });
    } catch (error) {
      console.error('💥 登录异常:', error); // 简化错误日志
      res.status(500).json({ error: '登录过程中发生错误' }); // 移除success和code
    }
  }
);

// 添加刷新令牌路由
router.post('/refresh-token', async (req, res) => {
  try {
    // 从请求头获取令牌
    const token = req.headers.authorization?.split(' ')[1];
    if (!token) {
      return res.status(401).json({ error: '未提供令牌' });
    }

    // 验证令牌
    const decoded = jwt.verify(token, process.env.JWT_SECRET || 'your-secret-key');
    
    // 检查令牌是否即将过期（例如，在5分钟内过期）
    const now = Date.now() / 1000;
    if (decoded.exp - now > 300) {
      // 如果令牌还有超过5分钟才过期，则无需刷新
      return res.status(400).json({ error: '令牌未过期' });
    }

    // 生成新令牌
    const newToken = jwt.sign(
      { userId: decoded.userId, username: decoded.username, role: decoded.role },
      process.env.JWT_SECRET || 'your-secret-key',
      { expiresIn: '1h' }
    );

    res.json({ 
      success: true, 
      token: newToken
    });
  } catch (error) {
    if (error.name === 'TokenExpiredError') {
      return res.status(401).json({ error: '令牌已过期，请重新登录' });
    }
    res.status(401).json({ error: '无效令牌' });
  }
});

// 登出路由（JWT 无状态，只需前端移除令牌）
router.post('/logout', (req, res) => {
  console.log('👋 用户登出', {
    timestamp: new Date().toISOString()
  });
  
  res.json({ 
    success: true, 
    message: '已登出' 
  });
});

// 受保护的个人信息路由
router.get(
  '/profile', 
  authenticateToken, // 使用认证中间件
  async (req, res) => {
    try {
      const userId = req.user.userId;
      
      // 从数据库获取用户详细信息
      const userProfile = db.getUserProfile(userId);
      
      if (!userProfile) {
        return res.status(404).json({ 
          success: false, 
          error: '用户资料不存在',
          code: 'PROFILE_NOT_FOUND'
        });
      }
      
      res.json({ 
        success: true, 
        profile: {
          id: userProfile.id,
          username: userProfile.username,
          role: userProfile.role,
          createdAt: userProfile.createdAt
        } 
      });
    } catch (error) {
      console.error('💥 获取用户资料异常:', {
        errorMessage: error.message,
        errorStack: error.stack,
        timestamp: new Date().toISOString()
      });
      
      res.status(500).json({ 
        success: false, 
        error: '获取用户资料失败',
        code: 'INTERNAL_SERVER_ERROR'
      });
    }
  }
);

// 添加缺失的路由定义（根据错误信息，这可能是导致问题的原因）
router.get('/me', authenticateToken, async (req, res) => {
  try {
    // 返回当前用户信息
    res.json({
      success: true,
      user: {
        userId: req.user.userId,
        username: req.user.username,
        role: req.user.role
      }
    });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: '获取用户信息失败',
      code: 'INTERNAL_SERVER_ERROR'
    });
  }
});

export default router;